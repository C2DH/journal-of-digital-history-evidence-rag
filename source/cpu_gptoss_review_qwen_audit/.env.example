# CPU-only JDH Evidence-RAG configuration using two GGUF models
#
# Step 1 / file 1: GPT-OSS-120B GGUF for reviewer PDF extraction.
# Step 3 / file 3: Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-GGUF for final Evidence-RAG audit inference.

# ---------------------------------------------------------------------
# Step 1 model: review extraction
# ---------------------------------------------------------------------
REVIEW_GGUF_REPO_ID=unsloth/gpt-oss-120b-GGUF
REVIEW_GGUF_FILENAME=Q2_K/gpt-oss-120b-Q2_K-00001-of-00002.gguf

# Optional: use a local GPT-OSS-120B GGUF file instead of downloading from Hugging Face.
# Example: REVIEW_GGUF_LOCAL_PATH=models/gpt-oss-120b-Q2_K-00001-of-00002.gguf
REVIEW_GGUF_LOCAL_PATH=

# ---------------------------------------------------------------------
# Step 3 model: final Evidence-RAG audit inference
# ---------------------------------------------------------------------
AUDIT_GGUF_REPO_ID=Jackrong/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-GGUF
AUDIT_GGUF_FILENAME=Qwen3.5-27B.Q4_K_M.gguf

# Optional: use a local Qwen audit GGUF file instead of downloading from Hugging Face.
# Example: AUDIT_GGUF_LOCAL_PATH=models/Qwen3.5-27B.Q4_K_M.gguf
AUDIT_GGUF_LOCAL_PATH=

# CPU inference settings. Increase N_THREADS to match your CPU cores.
N_THREADS=16
N_CTX=32768
N_BATCH=512
MAX_TOKENS_REVIEW=4096
MAX_TOKENS_AUDIT=2048
TEMPERATURE=0.1

# Embedding model. For faster CPU use bge-small. For stronger retrieval use BAAI/bge-large-en-v1.5.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Local folders
PAPER_LINKS_FILE=data/paper_links/paper_links.txt
REVIEW_UPLOAD_DIR=data/review_pdfs_upload
PAPERS_RAW_DIR=data/papers_raw
PAPERS_TEXT_DIR=data/papers_text
REVIEW_ORGANIZED_DIR=data/review_pdfs_organized
PROCESSED_REVIEWS_DIR=data/processed_reviews
VECTOR_DB_DIR=data/vector_db
OUTPUTS_DIR=outputs
